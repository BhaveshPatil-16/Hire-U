{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@hireu/shared": [
        "../../packages/shared/src/index.ts"
      ]
    },
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "server.ts",
    "../../packages/shared/src/**/*.ts"
  ]
}
