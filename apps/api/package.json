{
  "name": "@hireu/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild ./server.ts --bundle --platform=node --format=cjs --packages=external --alias:@hireu/shared=../../packages/shared/src/index.ts --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hireu/shared": "0.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "nodemailer": "^9.0.3",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
